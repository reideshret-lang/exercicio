#include <stdio.h>
#include <math.h>

int main()
{
    float x1, x2, y1, y2, d;
    
    printf("Insira os pontos A: (x1, y1)\n");
    scanf("%f, %f", &x1, &y1);
    printf("Insira os pontos B: (x2, y2)\n");
    scanf("%f, %f", &x2, &y2);
    
    d = sqrt(pow((x2 - x1),2) + pow((y2 - y1), 2));
    
    printf("A distancia entre os pontos é de %.2f", d);

    return 0;
}
