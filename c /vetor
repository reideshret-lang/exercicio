// Crie um programa em C que armazene 15 números inteiros
// Informe a quantidade de numeros pares
// informe a quantidade de numeros impares
// procure no vetor se alguma posicao tem o numero 30; Se sim, informe a posicao
// informe o maior e menor numero

#include <stdio.h>

int main()
{
    int num[15];
    int par, impar, maior, menor, trinta, i, j;
    
    for (i = 0; i < 15; i++){
        printf("Digite o número da posição %d: ", i + 1);
        scanf("%d", &num[i]);
    }
    
    maior = num[0];
    menor = num[0];
    par = 0;
    impar = 0;
    
    for (i = 0; i < 15; i++){
        if(num[i] % 2 == 0){
            par++;
        } else {
            impar++;
        }
        
        if(num[i] > maior){
            maior = num[i];
        }
        
        if(num[i] < menor){
            menor = num[i];
        }
        
        if(num[i] == 30){
        printf("\nO número 30 foi encontrado na posição %d\n", i + 1);
        } 
    }
    
    printf("\nQuantidade de pares: %d\n", par);
    printf("Quantidade de impares: %d\n", impar);
    printf("Maior: %d\n", maior);
    printf("Menor: %d\n", menor);

return 0;

