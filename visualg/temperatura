Algoritmo "Temperatura"

Var

   Temperatura : caractere
   f, c : real

Inicio

   Escreval("Qual escala você vai digitar a temperatura?(C/F)")
   leia(temperatura)
   
   Se (temperatura = "F") ou (temperatura = "f") entao
     escreval("Digite a temperatura em Fahrenheit: ")
     leia(f)
     c <- 5/9 * (f - 32)
     escreval("Temperatura equivalente em Celcius: ", c:2:2)
   senao
     se (temperatura = "C") ou (temperatura = "c") entao
        escreval("Digite a temperatura em Celcius: ")
        leia(c)
        f <- (c * 1.8) + 32
        escreval("Temperatura equivalente em Fahrenheit: ", f:2:2)
     senao
     escreval("Temperatura inválida")
     fimse
   fimse
   
   

Fimalgoritmo
