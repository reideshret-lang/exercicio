Algoritmo "mais_velho"

Var

  quantidade, i, maior : inteiro
  v_nome : vetor [0..9] de caractere
  v_idade : vetor [0..9] de inteiro

Inicio

  escreva("Quantas pessoas voce vai digitar? ")
  leia(quantidade)

  para i de 0 ate quantidade - 1 faca
    escreval("DADOS DA", i + 1, "a PESSOA:")
    escreva("NOME: ")
    leia(v_nome[i])
    escreva("IDADE: ")
    leia(v_idade[i])
  fimpara
  
  maior <- 0
  para i de 0 ate quantidade - 1 faca
    se maior < v_idade[i] entao
      maior <- v_idade[i]
    fimse
  fimpara
  
  para i de 0 ate quantidade - 1 faca
    se maior = v_idade[i] entao
      escreval("PESSOA MAIS VELHA: ", v_nome[i])
    fimse
  fimpara
  

Fimalgoritmo
