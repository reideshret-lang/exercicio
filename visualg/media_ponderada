Algoritmo "media_ponderada"


Var

  quantidade, i : inteiro
  x, y, z : real
  media : real

Inicio

    escreval("Quantos casos voce ira digitar?")
    leia(quantidade)
    
    para i de 1 ate quantidade faca
      escreval("Digite tres numeros:")
      leia(x)
      leia(y)
      leia(z)
      media <- ((x * 2) + (y * 3) + (z * 5)) / 10
      escreval("MEDIA = ", media:1:1)
    fimpara

Fimalgoritmo
