Algoritmo "alturas"

Var

   quantidade, i, dezesseis : inteiro
   v_nome : vetor [0..9] de caractere
   v_idade : vetor [0..9] de inteiro
   v_altura : vetor [0..9] de real
   soma, media, porcentagem : real

Inicio

   escreva("Quantas pessoas serao digitadas? ")
   leia(quantidade)
   
   para i de 0 ate quantidade - 1 faca
      escreval("Dados da", i+1, "a pessoa:")
      escreva("Nome: ")
      leia(v_nome[i])
      escreva("Idade: ")
      leia(v_idade[i])
      escreva("Altura: ")
      leia(v_altura[i])
   fimpara
   
   soma <- 0
   dezesseis <- 0
   
   para i de 0 ate quantidade - 1 faca
      soma <- soma + v_altura[i]
   fimpara
   
   media <- soma / quantidade
   
   para i de 0 ate quantidade - 1 faca
     se v_idade[i] < 16 entao
       dezesseis <- dezesseis + 1
     fimse
   fimpara
   
   porcentagem <- dezesseis / quantidade * 100
   
   escreval
   escreval("Altura media: ", media:3:2)
   escreval("Pessoas com menos de 16 anos: ",porcentagem:3:1,"%")
   para i de 0 ate quantidade - 1 faca
     se v_idade[i] < 16 entao
       escreval(v_nome[i])
     fimse
   fimpara

Fimalgoritmo
