Algoritmo "matriz_geral"

Var

  N, i, j, L, C: inteiro
  m_quadrada : vetor [0..9, 0..9] de real
  soma: real

Inicio

  escreva("Qual a ordem da matriz? ")
  leia(N)
  
  para i de 0 ate N-1 faca
    para j de 0 ate N-1 faca
      escreva("Elemento [",i,",",j,"]: ")
      leia(m_quadrada[i,j])
    fimpara
  fimpara
  
  soma <- 0
  para i de 0 ate N-1 faca
    para j de 0 ate N-1 faca
      se m_quadrada[i,j] > 0 entao
        soma <- soma + m_quadrada[i,j]
      fimse
    fimpara
  fimpara
  
  escreval
  escreva("SOMA DOS POSITIVOS: ", soma:3:1)

  escreval
  escreva("Escolha uma linha: ")
  leia(L)
  escreva("LINHA ESCOLHIDA: ")
  para j de 0 ate N-1 faca
    escreva(m_quadrada[L, j]:3:1, " ")
  fimpara

  escreval
  escreva("Escolha uma coluna: ")
  leia(C)
  escreva("COLUNA ESCOLHIDA: ")
  para i de 0 ate N-1 faca
    escreva(m_quadrada[i, C]:3:1, " ")
  fimpara

  escreval
  escreva("DIAGONAL PRINCIPAL: ")
  para i de 0 ate N-1 faca
      escreva(m_quadrada[i,i]:3:1, " ")
  fimpara
  
  escreval
  escreva("MATRIZ ALTERADA: ")
  para i de 0 ate N-1 faca
    para j de 0 ate N-1 faca
      se m_quadrada[i,j] < 0 entao
      m_quadrada[i,j] <- m_quadrada[i,j] ^ 2
      fimse
    fimpara
  fimpara
  
  para i de 0 ate N-1 faca
    escreval
    para j de 0 ate N-1 faca
      escreva(m_quadrada[i,j]:3:1, " ")
    fimpara
  fimpara

Fimalgoritmo
