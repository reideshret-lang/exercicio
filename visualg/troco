Algoritmo "Troco"

Var

  preco : real
  quantidade : inteiro
  recebido, troco : real

Inicio

  escreval("Preço unitário de um produto: ")
  leia(preco)
  escreval("Quantidade comprada: ")
  leia(quantidade)
  escreval("Dinheiro recebido: ")
  leia(recebido)
  troco <- recebido - (preco * quantidade)
  escreval("TROCO = ", troco:2:2)


Fimalgoritmo
